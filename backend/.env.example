APP_NAME="AegisFlow AI"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Ngôn ngữ mặc định: vi (Tiếng Việt)
APP_LOCALE=vi
APP_FALLBACK_LOCALE=vi

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ============================================================
# DATABASE — PostgreSQL với PostGIS (Production)
# ============================================================
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=aegisflow_db
DB_USERNAME=aegisflow_user
DB_PASSWORD=

# ============================================================
# Development: SQLite (không hỗ trợ PostGIS)
# ============================================================
# DB_CONNECTION=sqlite
# DB_DATABASE=/path/to/database.sqlite

# ============================================================
# BROADCASTING — Laravel Reverb (WebSocket)
# ============================================================
BROADCAST_CONNECTION=reverb

# Laravel Reverb (khuyến nghị)
REVERB_APP_ID=aegisflow
REVERB_APP_KEY=aegisflow-key
REVERB_APP_SECRET=aegisflow-secret
REVERB_HOST=127.0.0.1
REVERB_PORT=6001
REVERB_SCHEME=http

# Pusher (thay thế)
PUSHER_APP_ID=aegisflow
PUSHER_APP_KEY=aegisflow-key
PUSHER_APP_SECRET=aegisflow-secret
PUSHER_HOST=127.0.0.1
PUSHER_PORT=6001
PUSHER_SCHEME=http

# ============================================================
# CACHE & SESSION
# ============================================================
CACHE_STORE=database
SESSION_DRIVER=database
SESSION_LIFETIME=120

# ============================================================
# QUEUE
# ============================================================
QUEUE_CONNECTION=database

# ============================================================
# REDIS
# ============================================================
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ============================================================
# MAIL
# ============================================================
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@aegisflow.ai"
MAIL_FROM_NAME="${APP_NAME}"

# ============================================================
# FILE STORAGE
# ============================================================
FILESYSTEM_DISK=local
UPLOAD_DISK=public

# ============================================================
# GOOGLE OAUTH (Đăng nhập Google)
# ============================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL="${APP_URL}/api/auth/google/callback"

# ============================================================
# AI SERVICES — Groq API (NLP & Vision)
# ============================================================
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# ============================================================
# AI SERVICE — Python FastAPI (Dự báo lũ)
# ============================================================
AI_SERVICE_URL=http://localhost:8001
AI_SERVICE_KEY=
AI_PREDICTION_TIMEOUT=30

# ============================================================
# THRESHOLDS — Ngưỡng cảnh báo mặc định
# ============================================================
FLOOD_ALERT_THRESHOLD_M=1.5
FLOOD_DANGER_THRESHOLD_M=3.0
FLOOD_FLOOD_THRESHOLD_M=5.0
SENSOR_READING_INTERVAL=300
SENSOR_OFFLINE_TIMEOUT=600

# ============================================================
# FCM — Firebase Cloud Messaging
# ============================================================
FCM_SERVER_KEY=
FCM_PROJECT_ID=

# ============================================================
# OPENWEATHERMAP API
# ============================================================
OPENWEATHER_API_KEY=
